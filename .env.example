# LLM endpoints
OPENROUTER_API_KEY=
PRIMARY_REASONING_MODEL=         # optional override; if unset, pool auto-resolves

# Optional model-specific keys (single OPENROUTER_API_KEY is sufficient)
OPENROUTER_NEMOTRON=
OPENROUTER_GLM=

# Groq (used by Materiality_Classifier, Search_Summarizer)
GROQ_API_KEY=

# Data providers
FINNHUB_API_KEY=
FRED_API_KEY=

# Brokerage (paper trading - Phase 6+)
ALPACA_PAPER_KEY=
ALPACA_PAPER_SECRET=
ALPACA_LIVE_KEY=
ALPACA_LIVE_SECRET=
NEMO_PAPER_MODE=true             # set false ONLY after passing real-money gate

# Alerts (Phase 2+)
DISCORD_WEBHOOK_URL=

# SEC identity for edgartools
NAME="Your Name"
SEC_EMAIL="you@example.com"

# Scraper search backend
SEARXNG_URL=http://localhost:8888

# System operating mode
NEMO_WATCHLIST=AAPL,MSFT,GOOGL,NVDA,TSLA,JPM,KO  # default monitored tickers
