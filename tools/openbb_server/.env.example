# OpenBB MCP server environment variables.
#
# The default-provider tools (insider_trading, news_company, options_chains,
# analyst_consensus) work without any of these. The rest unlock additional
# tools that this server registers but returns a clear "missing credential"
# error envelope when the underlying provider isn't configured.
#
# Copy to ~/.openbb_user_settings.json or load via dotenv before launching
# the server. Each key is optional.

OPENBB_PAT=
FMP_API_KEY=
INTRINIO_API_KEY=
BENZINGA_API_KEY=
TIINGO_API_KEY=
