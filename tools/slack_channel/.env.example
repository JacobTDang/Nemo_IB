# Slack channel plugin env vars.
# Real values live in ~/.claude/channels/slack/.env (outside the repo).
# This file is checked in as documentation only; copy it, fill in values,
# and place the result at ~/.claude/channels/slack/.env.

# Bot User OAuth Token from the Slack app's "OAuth & Permissions" page.
SLACK_BOT_TOKEN=xoxb-your-bot-token

# App-Level Token (Socket Mode) from the Slack app's "Basic Information" page.
# Required scope: connections:write.
SLACK_APP_TOKEN=xapp-your-app-token

# Optional single-user allowlist fast-path. If unset, the plugin reads
# ~/.claude/channels/slack/access.json. Find your Slack user ID via
# Slack -> your profile -> kebab menu -> Copy member ID.
SLACK_ALLOWED_USER_ID=U0123456789
